# Scion Hub Environment Configuration
# Copy to .scratch/hub.env and fill in values before running gce-start-hub.sh

# === Required ===
SCION_HUB_STORAGE_BUCKET=scion-demo-templates
SESSION_SECRET=<generate-with-openssl-rand-base64-32>

# === Hub & Registry ===
SCION_HUB_ENDPOINT=https://hub.demo.scion-ai.dev
SCION_IMAGE_REGISTRY=us-central1-docker.pkg.dev/ptone-misc/public-docker

# === Telemetry (OTEL) ===
# Hub-side telemetry configuration. These are loaded by the systemd unit
# via EnvironmentFile=/home/scion/.scion/hub.env.
SCION_CLOUD_LOGGING=true
SCION_GCP_PROJECT_ID=deploy-demo-test
GOOGLE_CLOUD_PROJECT=deploy-demo-test
SCION_OTEL_ENDPOINT=cloudtrace.googleapis.com:443
SCION_OTEL_LOG_ENABLED=true

# === Optional ===
# SCION_LOG_LEVEL=debug
